<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Financeiro | Refrigeração Eliezer</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    
    <style>
        :root { --bg-body: #0d1117; --text-main: white; --glass-bg: rgba(255, 255, 255, 0.03); --glass-border: rgba(255, 255, 255, 0.1); }
        body { background: var(--bg-body); color: var(--text-main); font-family: 'Inter', sans-serif; -webkit-user-select: none; user-select: none; }
        .glass-card { background: var(--glass-bg); backdrop-filter: blur(20px); border: 1px solid var(--glass-border); border-radius: 20px; transition: 0.3s; }
        .devedor-border { border-left: 4px solid #ef4444 !important; }
        .pago-border { border-left: 4px solid #22c55e !important; }
        
        /* Ocultar barra de rolagem */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="p-4 pb-24">

    <div class="max-w-4xl mx-auto">
        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-xl font-black uppercase tracking-tighter">Contas a <span class="text-red-500">Receber</span></h1>
                <span class="text-[10px] opacity-40 font-bold uppercase tracking-widest">Gestão de Inadimplência</span>
            </div>
            <div class="text-right">
                <p class="text-[10px] opacity-50 font-black uppercase">Total Pendente</p>
                <p id="total-geral" class="text-2xl font-black text-red-500">R$ 0,00</p>
            </div>
        </header>

        <div class="flex gap-2 overflow-x-auto pb-4 no-scrollbar mb-4">
            <button onclick="filtrarStatus('pendente')" class="filter-btn bg-red-500/20 text-red-500 border border-red-500/50 px-4 py-2 rounded-full text-xs font-bold uppercase">Pendentes</button>
            <button onclick="filtrarStatus('todos')" class="filter-btn bg-white/5 text-white/50 border border-white/10 px-4 py-2 rounded-full text-xs font-bold uppercase">Ver Todos</button>
        </div>

        <div class="relative mb-6">
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 opacity-30 text-sm"></i>
            <input type="text" id="buscaDevedor" oninput="renderizarFinanceiro()" placeholder="Buscar cliente ou serviço..." class="w-full bg-white/5 border border-white/10 rounded-xl py-3 pl-12 pr-4 outline-none focus:border-red-500 transition-all text-sm">
        </div>

        <div id="container-financeiro" class="space-y-4">
            <div class="flex flex-col items-center justify-center py-20">
                <div class="animate-spin rounded-full h-12 w-12 border-4 border-white/5 border-t-red-500 mb-4"></div>
                <p class="text-[10px] font-black uppercase tracking-widest opacity-40">Consultando Planilha...</p>
            </div>
        </div>
    </div>

    <script>
        // URL da sua planilha (aba "receber")
        const URL_FINANCEIRO = "https://script.google.com/macros/s/AKfycbw-IhS6uY5JWpmvsFIrGJv0C_WkzYnpRozN3Ed2AVBhOcs8-9CCprZUsCjaYj4F-tGE2A/exec"; 

        let dadosFinanceiros = [];
        let filtroStatus = 'pendente';

        async function carregarDados() {
            try {
                // Aqui você deve garantir que seu script retorne as colunas: 
                // CLIENTE, SERVICO, VALOR_TOTAL, VALOR_RECEBIDO, STATUS
                const res = await fetch(URL_FINANCEIRO);
                dadosFinanceiros = await res.json();
                renderizarFinanceiro();
            } catch (e) {
                document.getElementById('container-financeiro').innerHTML = `<div class="text-center py-10 opacity-50 font-bold">ERRO AO CARREGAR DADOS</div>`;
            }
        }

        function formatarMoeda(valor) {
            return parseFloat(valor || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
        }

        function renderizarFinanceiro() {
            const container = document.getElementById('container-financeiro');
            const busca = document.getElementById('buscaDevedor').value.toLowerCase();
            let somaPendente = 0;

            const filtrados = dadosFinanceiros.filter(item => {
                // Cálculo da Coluna E (Falta Pagar) conforme sua imagem
                const total = parseFloat(item.VALOR_TOTAL || 0);
                const recebido = parseFloat(item.VALOR_RECEBIDO || 0);
                const faltaPagar = total - recebido;
                item.faltaPagar = faltaPagar;

                const matchBusca = item.CLIENTE.toLowerCase().includes(busca) || item.SERVICO.toLowerCase().includes(busca);
                
                if (filtroStatus === 'pendente') {
                    return matchBusca && faltaPagar > 0;
                }
                return matchBusca;
            });

            if (filtrados.length === 0) {
                container.innerHTML = `<div class="text-center py-10 opacity-20 font-bold uppercase text-xs">Nenhum registro encontrado</div>`;
                document.getElementById('total-geral').innerText = "R$ 0,00";
                return;
            }

            container.innerHTML = filtrados.map(item => {
                const isPendente = item.faltaPagar > 0;
                if(isPendente) somaPendente += item.faltaPagar;

                return `
                    <div class="glass-card p-5 ${isPendente ? 'devedor-border' : 'pago-border'}">
                        <div class="flex justify-between items-start">
                            <div class="flex-1">
                                <h2 class="text-base font-black leading-tight uppercase">${item.CLIENTE}</h2>
                                <p class="text-xs opacity-60 mb-3">${item.SERVICO}</p>
                                
                                <div class="grid grid-cols-2 gap-2 mt-2">
                                    <div class="bg-white/5 p-2 rounded-lg">
                                        <p class="text-[9px] opacity-40 uppercase font-bold">Total</p>
                                        <p class="text-sm font-bold">${formatarMoeda(item.VALOR_TOTAL)}</p>
                                    </div>
                                    <div class="bg-white/5 p-2 rounded-lg">
                                        <p class="text-[9px] opacity-40 uppercase font-bold">Recebido</p>
                                        <p class="text-sm font-bold text-green-500">${formatarMoeda(item.VALOR_RECEBIDO)}</p>
                                    </div>
                                </div>
                            </div>

                            <div class="text-right ml-4">
                                <span class="text-[9px] font-black uppercase ${isPendente ? 'text-red-500' : 'text-green-500'}">
                                    ${isPendente ? 'Falta Pagar' : 'Quitado'}
                                </span>
                                <p class="text-lg font-black ${isPendente ? 'text-red-500' : 'text-green-500'}">
                                    ${formatarMoeda(item.faltaPagar)}
                                </p>
                                <button class="mt-4 text-[10px] bg-white/10 px-3 py-1 rounded-md hover:bg-white/20 transition-all uppercase font-bold">
                                    <i class="fa-solid fa-comment-dollar mr-1"></i> Cobrar
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            document.getElementById('total-geral').innerText = formatarMoeda(somaPendente);
        }

        function filtrarStatus(status) {
            filtroStatus = status;
            renderizarFinanceiro();
        }

        window.onload = carregarDados;
    </script>
</body>
</html>
